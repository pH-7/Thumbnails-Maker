{
  "name": "thumbnail-maker",
  "productName": "YouTube Thumbnail Creator",
  "version": "3.2.6",
  "description": "Create professional YouTube thumbnails with multiple images, custom layouts, and intelligent enhancement features.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "test:ci": "jest --runInBand --coverage",
    "check:syntax": "node --check main.js && node --check scripts/mas-publish-pipeline.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "mas-publish": "node scripts/mas-publish-pipeline.js",
    "setup": "electron-builder install-app-deps && npm run rebuild-sharp",
    "rebuild-sharp": "npx @electron/rebuild -f -w sharp"
  },
  "author": "Pierre-Henry Soria",
  "homepage": "https://github.com/pH-7/Thumbnails-Maker",
  "license": "MIT",
  "build": {
    "appId": "ph7.me.youtube-thumbnail-combiner",
    "productName": "YouTube Thumbnail Creator",
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "files": [
      "**/*",
      "!**/*.p8",
      "!**/*.p12",
      "!**/*.mobileprovision",
      "!**/*.provisionprofile",
      "!.env",
      "!.env.*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/mac/icon.icns",
      "extendInfo": {
        "CFBundleIconName": "icon",
        "CFBundleIconFile": "icon.icns"
      },
      "hardenedRuntime": true,
      "timestamp": "none",
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "entitlementsLoginHelper": "build/entitlements.loginhelper.plist",
      "target": [
        "mas",
        "dmg"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "mas": {
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "entitlementsLoginHelper": "build/entitlements.loginhelper.plist",
      "hardenedRuntime": false,
      "timestamp": "none",
      "provisioningProfile": "build/embedded.provisionprofile",
      "type": "distribution",
      "category": "public.app-category.graphics-design",
      "binaries": [
        "Contents/Resources/app.asar.unpacked/node_modules/sharp/build/Release/sharp-*.node",
        "Contents/Resources/app.asar.unpacked/node_modules/sharp/vendor/**/lib/*.dylib",
        "Contents/Resources/app/node_modules/sharp/build/Release/sharp-*.node",
        "Contents/Resources/app/node_modules/sharp/vendor/**/lib/*.dylib"
      ],
      "artifactName": "${productName}-${version}.pkg"
    },
    "afterSign": "scripts/notarize.js"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "dotenv": "^17.4.0",
    "sharp": "^0.32.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/osx-sign": "^1.3.3",
    "@electron/packager": "^18.4.0",
    "@electron/rebuild": "^3.2.9",
    "electron": "^25.9.8",
    "electron-builder": "^24.0.0",
    "jest": "^29.7.0"
  }
}
