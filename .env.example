APP_IDENTIFIER=com.example.yourapp

# Code signing
CSC_IDENTITY_AUTO_DISCOVERY=true
CSC_NAME=Apple Distribution: Your Name (XXXXXXXXXX)
TEAM_ID=XXXXXXXXXX
APPLE_ID=you@example.com

# App Store Connect API credentials
APPLE_STORE_TEAM_ID=XXXXXXXXX
APPLE_TEAM_ID=XXXXXXXXXX
APP_STORE_KEY_ID=XXXXXXXXXX
APP_STORE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# iOS (iPhone) app — Fastlane :ios platform
IOS_APP_IDENTIFIER=me.ph7.youtubethumbnailmaker
IOS_APP_VERSION=1.0.0
# Note: iOS signing uses Xcode automatic signing via the App Store Connect API
# key above (no `match` repo or passphrase required).

