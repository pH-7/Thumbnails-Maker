git_url("https://github.com/pH-7/YouTube-Thumbnail-Creator-Certs.git")

type("appstore") # The default type, can be: appstore, adhoc, development, enterprise
app_identifier(ENV['APP_IDENTIFIER'])
team_id(ENV['TEAM_ID'])

# Set storage mode to git
storage_mode("git")

# Force to create new certificates even if old ones exist
force(true)
force_for_new_devices(true)

