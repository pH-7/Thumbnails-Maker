# Dependency directories
node_modules/
vendor/
.bundle/

# Build folder — contains signing identities, provisioning profiles, and team IDs
build/

# Build output directories
dist/
out/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Secrets & environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# Fastlane — track lane definitions, exclude generated reports
fastlane/report.xml
fastlane/Preview.html

# Xcode user specific files
*.xcuserstate
xcuserdata/

# Electron artifacts
*.asar
electron-builder.yml

# Compiled files
*.tsbuildinfo
*.pid
*.seed

# Generated build config (copy from mas-build-config.example.json and fill in your values)
mas-build-config.json

# Certificate request artifacts
certs/

# Certificates and provisioning profiles
*.p8
*.p12
*.cer
*.key
*.certSigningRequest
*.pem
*.mobileprovision
*.provisionprofile
